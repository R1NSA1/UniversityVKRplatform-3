# Копировать в .env и менять значения!

# PostgreSQL (обязательно)
POSTGRES_USER=postgres              # стандартный пользователь (можно не менять)
POSTGRES_PASSWORD=secure_vkr_2026   # сильный пароль, меняй на свой
POSTGRES_DB=vkr_main

# JWT (обязательно для Auth)
JWT_SECRET=change_this_to_a_very_long_random_string_64_chars_min_2026
JWT_ALGORITHM=HS256                 # проще для начала, RS256 требует ключей

# ---------------------------------------------------------------------------
# email-service: SMTP для ВСЕХ писем (вход + коды заявок)
# Без SMTP письма НЕ приходят в ящик — только код на экране и в логах:
#   docker compose logs -f email-service
# ---------------------------------------------------------------------------

# Gmail (пароль приложения: https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_SSL=false
# SMTP_USE_STARTTLS=true
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Yandex
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_USER=your@yandex.ru
SMTP_PASSWORD=your-app-password

# auth-service / topic-service → email-service (в Docker менять не нужно)
# EMAIL_SERVICE_URL=http://email-service:8000

# Код входа: показывать на экране после login (для отладки)
SHOW_LOGIN_CODE=true
LOG_LOGIN_CODE=true
LOGIN_CODE_EMAIL_SUBJECT=Код входа в платформу ВКР

# false = код только на экране; true = отправка через email-service
SEND_EMAIL_CODES=false
